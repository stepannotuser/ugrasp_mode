// SVGraph my_fsm
// File    my_fsm_full_graphviz.dot


digraph my_fsm {
  pad="0.5"
  __START__ [label="__START__" fillcolor=lightgrey style=filled];
  __START__ -> __START___body;
  IDLE_body [label="IDLE_body()" shape=box style=filled fillcolor=darkseagreen1];
  IDLE_sel [label="" shape=diamond height="0.3" width="0.3"];
  IDLE_body -> IDLE_sel;
  IDLE_to_READ_body [label="IDLE_to_READ_body()" shape=box style=filled fillcolor=lightcyan];
  IDLE_sel -> IDLE_to_READ_body
  IDLE_to_READ_body -> READ_body;
  READ_body [label="READ_body()" shape=box style=filled fillcolor=darkseagreen1];
  READ_sel [label="" shape=diamond height="0.3" width="0.3"];
  READ_body -> READ_sel;
  READ_to_WRITE_body [label="READ_to_WRITE_body()" shape=box style=filled fillcolor=lightcyan];
  READ_sel -> READ_to_WRITE_body
  READ_to_WRITE_body -> WRITE_body;
  WRITE_body [label="WRITE_body()" shape=box style=filled fillcolor=darkseagreen1];
  WRITE_sel [label="" shape=diamond height="0.3" width="0.3"];
  WRITE_body -> WRITE_sel;
  WRITE_to_DONE_body [label="WRITE_to_DONE_body()" shape=box style=filled fillcolor=lightcyan];
  WRITE_sel -> WRITE_to_DONE_body
  WRITE_to_DONE_body -> DONE_body;
  DONE_body [label="DONE_body()" shape=box style=filled fillcolor=darkseagreen1];
  DONE_sel [label="" shape=diamond height="0.3" width="0.3"];
  DONE_body -> DONE_sel;
  DONE_to_DONE_body [label="DONE_to_DONE_body()" shape=box style=filled fillcolor=lightcyan];
  DONE_sel -> DONE_to_DONE_body
  DONE_to_DONE_body -> DONE_body;
  __START___body [label="__START___body()" shape=box style=filled fillcolor=darkseagreen1];
  __START___sel [label="" shape=diamond height="0.3" width="0.3"];
  __START___body -> __START___sel;
  __START___to_IDLE_body [label="__START___to_IDLE_body()" shape=box style=filled fillcolor=lightcyan];
  __START___sel -> __START___to_IDLE_body
  __START___to_IDLE_body -> IDLE_body;
}
